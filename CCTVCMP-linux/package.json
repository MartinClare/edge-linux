{
  "name": "axon-vision-cmp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "sh -c 'ORIG_DATABASE_URL=\"$DATABASE_URL\"; MIGRATE_DATABASE_URL=\"${DIRECT_URL:-$ORIG_DATABASE_URL}\"; DATABASE_URL=\"$MIGRATE_DATABASE_URL\" prisma migrate deploy'",
    "prisma:seed": "tsx prisma/seed.ts",
    "bootstrap-admin": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/bootstrap-admin.ts",
    "seed-cameras": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/seed-cameras.ts",
    "db:push": "prisma db push",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.4.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.575.0",
    "next": "14.2.32",
    "nodemailer": "^6.10.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.17.5",
    "@types/nodemailer": "^6.4.23",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.32",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
