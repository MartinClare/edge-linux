# Copy to .env (do not commit .env). Fill with values for THIS deployment / site only.

# ── Neon database connections ──────────────────────────────────────────────────
# Recommended Neon setup:
#   DATABASE_URL  — pooled (-pooler host): used at runtime by the Next.js app
#   DIRECT_URL    — direct (no -pooler):   used by `prisma migrate deploy` in build
#
# Both point to the same Neon database; only the hostname differs.
# Get both from: Neon Console → your project → Connection Details
#   → toggle "Pooled connection" on/off to copy each URL.
#
# Set BOTH in Vercel: Settings → Environment Variables → add DATABASE_URL + DIRECT_URL.
# Build fallback: if DIRECT_URL is missing, the build falls back to DATABASE_URL.
# That avoids schema-validation failures, but for Neon the direct URL is still
# strongly recommended so migrations don't time out through the pooler.

DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Unique per CMP instance — signs session JWTs (32+ random chars).
JWT_SECRET="generate-a-long-random-secret-for-this-site-only"

# Must match centralServer.apiKey in THIS site’s edge app.config.json (edge-linux).
EDGE_API_KEY="your-edge-api-key-for-this-site"

# Vercel Deployment Protection bypass secret.
# REQUIRED if this CMP is on Vercel with Deployment Protection enabled (the default
# for preview/branch deployments).  Without it, Vercel blocks ALL inbound webhooks
# with 401 — the edge X-API-Key never reaches the Next.js handler.
#
# How to get it:
#   Vercel Dashboard → your project → Settings → Deployment Protection
#   → "Protection Bypass for Automation" → Generate / copy the secret.
#   Then also paste the same value into centralServer.vercelBypassToken in the
#   edge's app.config.json (or app.config (chev).json for the chev site).
#
# Alternative: disable Deployment Protection in Vercel (the EDGE_API_KEY still
# authenticates every webhook request, so the endpoint is not "open").
#
# VERCEL_AUTOMATION_BYPASS_SECRET="your-bypass-secret-here"

# CMP incident classification — OpenRouter key for this CMP deployment.
OPENROUTER_API_KEY="sk-or-v1-..."

# LLM call frequency limits — prevents over-spending when the edge sends frequently.
# Minimum 60 s is enforced even if you set a lower value.
# Text classifier: how often (seconds) to call the LLM per camera (default 60 = 1/min)
# LLM_RATE_LIMIT_SECONDS=60
# Vision verifier: how often (seconds) to send the image to the vision LLM per camera (default 120 = 1/2min)
# VISION_RATE_LIMIT_SECONDS=120

# LLM models used for CMP-side analysis (optional — defaults shown below).
#
# Text classifier  — reads the edge's text analysis and independently classifies
# incident types + risk levels using step-by-step "thinking" reasoning.
# Default: google/gemini-2.5-flash  ($0.30/M in, $2.50/M out — best reasoning/cost)
# Upgrade: anthropic/claude-sonnet-4-6  ($3/M in — best accuracy for edge cases)
# CLASSIFIER_MODEL="google/gemini-2.5-flash"
#
# Vision verifier  — analyses the actual JPEG image sent by the edge device and
# verifies whether the text description is accurate.
# Default: google/gemini-3-flash-preview  ($0.50/M in — #1 in Health, near-Pro vision)
# Upgrade: anthropic/claude-sonnet-4-6  ($3/M in — maximum accuracy)
# VISION_MODEL="google/gemini-3-flash-preview"

# One-time: create / reset an admin login (then run: npm run bootstrap-admin)
# CMP_BOOTSTRAP_EMAIL="you@example.com"
# CMP_BOOTSTRAP_PASSWORD="choose-a-strong-password"
# CMP_BOOTSTRAP_NAME="Your Name"
