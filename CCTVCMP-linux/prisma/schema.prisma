generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  project_manager
  safety_officer
  viewer
}

enum CameraStatus {
  online
  offline
  maintenance
}

enum IncidentType {
  ppe_violation
  fall_risk
  restricted_zone_entry
  machinery_hazard
  near_miss
  smoking
  fire_detected
  smoke_detected
}

enum IncidentRiskLevel {
  low
  medium
  high
  critical
}

enum IncidentStatus {
  open
  acknowledged
  resolved
  dismissed
  record_only
}

enum IncidentAction {
  created
  assigned
  acknowledged
  resolved
  updated
  dismissed
  note_added
}

enum ChannelType {
  email
  webhook
  dashboard
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  hashedPassword String   @map("hashed_password")
  role           Role     @default(viewer)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  assignedIncidents Incident[]    @relation("IncidentAssignee")
  incidentLogs      IncidentLog[]

  @@map("users")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cameras      Camera[]
  zones        Zone[]
  incidents    Incident[]
  dailyMetrics DailyMetric[]

  @@map("projects")
}

model Camera {
  id           String       @id @default(cuid())
  name         String
  edgeCameraId String?      @unique @map("edge_camera_id")
  streamUrl    String?      @map("stream_url")
  projectId    String       @map("project_id")
  zoneId       String?      @map("zone_id")
  status       CameraStatus @default(online)
  lastReportAt DateTime?    @map("last_report_at")
  createdAt    DateTime     @default(now()) @map("created_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zone        Zone?        @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  incidents   Incident[]
  edgeReports EdgeReport[]

  @@map("cameras")
}

model Zone {
  id        String            @id @default(cuid())
  projectId String            @map("project_id")
  name      String
  riskLevel IncidentRiskLevel @map("risk_level")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cameras   Camera[]
  incidents Incident[]

  @@map("zones")
}

model Incident {
  id             String            @id @default(cuid())
  projectId      String            @map("project_id")
  cameraId       String            @map("camera_id")
  zoneId         String            @map("zone_id")
  edgeReportId   String?           @map("edge_report_id")
  type           IncidentType
  riskLevel      IncidentRiskLevel @map("risk_level")
  status         IncidentStatus    @default(open)
  recordOnly     Boolean           @default(false) @map("record_only")
  notes          String?
  reasoning      String?
  detectedAt     DateTime          @default(now()) @map("detected_at")
  acknowledgedAt DateTime?         @map("acknowledged_at")
  resolvedAt     DateTime?         @map("resolved_at")
  dismissedAt    DateTime?         @map("dismissed_at")
  assignedTo     String?           @map("assigned_to")

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  camera           Camera            @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  zone             Zone              @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  edgeReport       EdgeReport?       @relation(fields: [edgeReportId], references: [id], onDelete: SetNull)
  assignee         User?             @relation("IncidentAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  logs             IncidentLog[]
  notificationLogs NotificationLog[]

  @@index([projectId])
  @@index([status])
  @@index([cameraId, type, detectedAt])
  @@map("incidents")
}

model IncidentLog {
  id         String         @id @default(cuid())
  incidentId String         @map("incident_id")
  userId     String         @map("user_id")
  action     IncidentAction
  timestamp  DateTime       @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("incident_logs")
}

model DailyMetric {
  projectId         String   @map("project_id")
  date              DateTime
  totalIncidents    Int      @default(0) @map("total_incidents")
  avgResponseTime   Float    @default(0) @map("avg_response_time")
  ppeComplianceRate Float    @default(0) @map("ppe_compliance_rate")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, date])
  @@map("daily_metrics")
}

model EdgeReport {
  id                     String    @id @default(cuid())
  cameraId               String    @map("camera_id")
  edgeCameraId           String    @map("edge_camera_id")
  cameraName             String    @map("camera_name")
  messageType            String    @default("analysis") @map("message_type")
  keepalive              Boolean   @default(false)
  eventImageIncluded     Boolean   @default(false) @map("event_image_included")
  eventImagePath         String?   @map("event_image_path")
  eventImageMimeType     String?   @map("event_image_mime_type")
  eventImageData         Bytes?    @map("event_image_data")
  eventTimestamp         DateTime? @map("event_timestamp")
  overallRiskLevel       String    @map("overall_risk_level")
  overallDescription     String    @map("overall_description")
  constructionSafety     Json?     @map("construction_safety_json")
  fireSafety             Json?     @map("fire_safety_json")
  propertySecurity       Json?     @map("property_security_json")
  peopleCount            Int?      @map("people_count")
  missingHardhats        Int?      @map("missing_hardhats")
  missingVests           Int?      @map("missing_vests")
  rawJson                Json      @map("raw_json")
  classificationJson     Json?     @map("classification_json")
  cmpRiskLevel           String?   @map("cmp_risk_level")
  visionVerificationJson Json?     @map("vision_verification_json")
  receivedAt             DateTime  @default(now()) @map("received_at")

  camera    Camera     @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  incidents Incident[]

  @@index([cameraId])
  @@index([receivedAt])
  @@index([cameraId, receivedAt])
  @@map("edge_reports")
}

model AlarmRule {
  id              String            @id @default(cuid())
  name            String
  incidentType    IncidentType      @map("incident_type")
  minRiskLevel    IncidentRiskLevel @default(low) @map("min_risk_level")
  minConfidence   Float             @default(0.7) @map("min_confidence")
  consecutiveHits Int               @default(1) @map("consecutive_hits")
  dedupMinutes    Int               @default(5) @map("dedup_minutes")
  enabled         Boolean           @default(true)
  recordOnly      Boolean           @default(false) @map("record_only")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@unique([incidentType])
  @@map("alarm_rules")
}

model NotificationChannel {
  id           String            @id @default(cuid())
  name         String
  type         ChannelType
  config       Json              @default("{}")
  minRiskLevel IncidentRiskLevel @default(low) @map("min_risk_level")
  enabled      Boolean           @default(true)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  logs NotificationLog[]

  @@map("notification_channels")
}

model NotificationLog {
  id         String   @id @default(cuid())
  channelId  String   @map("channel_id")
  incidentId String   @map("incident_id")
  status     String
  sentAt     DateTime @default(now()) @map("sent_at")
  error      String?

  channel  NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  incident Incident            @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([incidentId])
  @@map("notification_logs")
}
