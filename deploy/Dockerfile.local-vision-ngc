ARG BASE_IMAGE=nvcr.io/nvidia/pytorch:25.09-py3
FROM ${BASE_IMAGE}

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HUB_OFFLINE=1 \
    TRANSFORMERS_OFFLINE=1 \
    TRITON_PTXAS_PATH=/usr/local/cuda/bin/ptxas \
    TRITON_PTXAS_BLACKWELL_PATH=/usr/local/cuda/bin/ptxas

WORKDIR /app

COPY python/requirements-core.txt /tmp/requirements-core.txt

RUN python -m pip install --upgrade pip && \
    python -m pip install -r /tmp/requirements-core.txt \
      "accelerate>=1.0.0" \
      "safetensors>=0.4.5" \
      "transformers>=4.57.0" \
      "vllm" \
      "qwen-vl-utils>=0.0.8" \
      "timm>=1.0.0" \
      "Pillow>=10.0.0" && \
    python -m pip uninstall -y flash-attn

COPY python /app/python

WORKDIR /app/python
EXPOSE 8001

CMD ["python", "-m", "uvicorn", "app.local_vision_server:app", "--host", "0.0.0.0", "--port", "8001"]
