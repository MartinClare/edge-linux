[Unit]
Description=Edge Linux UI (serve static build)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=iris
Group=iris
WorkingDirectory=/home/iris/Documents/development/edge-linux/ppe-ui
ExecStart=/usr/bin/npx serve -s /home/iris/Documents/development/edge-linux/ppe-ui/build -l 3000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
