# Edge cloud API — copy to .env and adjust.

# Default vision.activeModel is local_gemma4_e4b → FastAPI on 8001.
# The FastAPI process embeds vLLM for Gemma when LOCAL_VISION_BACKEND=vllm.
LOCAL_VISION_API_URL=http://127.0.0.1:8001

# Optional direct OpenAI-compatible Qwen3-vLLM service (local_qwen3_vllm only).
LOCAL_VLLM_API_URL=http://127.0.0.1:8002
LOCAL_VLLM_MODEL=qwen3VL32B-8bit
LOCAL_VLLM_TIMEOUT_MS=600000
LOCAL_VLLM_MAX_CONCURRENT=2

OPENROUTER_API_KEY=
